# ============================================================
# Pepperfry Product Catalog Enrichment Pipeline — Case 5
# Mac Makefile  (enrich service only — run on Mac)
# ============================================================
#
# PREREQUISITES:
#   - Ollama installed: brew install ollama
#   - Model pulled:    ollama pull nomic-embed-text
#   - Ollama running:  ollama serve
#
# USAGE:
#   make -f Makefile.mac start        — start Ollama + Enrich Service (one shot)
#   make -f Makefile.mac stop         — stop Ollama + Enrich Service
#   make -f Makefile.mac health       — check if the Enrich Service is responding
#   make -f Makefile.mac ollama-serve — start Ollama in foreground (debugging only)
#
# EXECUTION ORDER (after Windows 'make setup' completes):
#   1. make -f Makefile.mac start
#   2. export PF_POSTGRES_PASSWORD=etl_pass
#   3. export ENRICH_SERVICE_URL=http://localhost:8765
#   4. Start flows: pid=34 → pid=35 → pid=32

ENRICH_PORT ?= 8765
OLLAMA_URL  ?= http://localhost:11434
TMPDIR      ?= /tmp/pf_case5

.PHONY: start stop ollama-serve enrich enrich-stop health

$(TMPDIR):
	mkdir -p $(TMPDIR)

## Start Ollama + Enrich Service in one shot
start: enrich-stop $(TMPDIR)
	@echo ">>> Starting Ollama on 0.0.0.0:11434..."
	@OLLAMA_HOST=0.0.0.0 ollama serve > $(TMPDIR)/ollama.log 2>&1 & echo $$! > $(TMPDIR)/ollama.pid
	@MAC_IP=$$(ipconfig getifaddr en0); \
	echo "  Waiting for Ollama at $$MAC_IP:11434..."; \
	for i in $$(seq 1 20); do \
		curl -sf http://$$MAC_IP:11434 > /dev/null 2>&1 && break; \
		printf "."; sleep 2; \
	done; \
	curl -sf --max-time 3 http://$$MAC_IP:11434 > /dev/null 2>&1 \
		&& echo "  ✓ Ollama ready at $$MAC_IP:11434" \
		|| { echo "  ✗ Ollama NOT accessible at $$MAC_IP:11434 — macOS firewall may be blocking port 11434"; \
		     echo "    Fix: System Settings → Privacy & Security → Firewall → allow ollama"; \
		     exit 1; }
	@$(MAKE) -f Makefile.mac enrich

## Start Ollama bound to all interfaces so Windows can reach it (foreground — for debugging)
ollama-serve:
	@echo ">>> Starting Ollama on 0.0.0.0:11434..."
	OLLAMA_HOST=0.0.0.0 ollama serve

## Build and start the Mac Enrich Service in the background
enrich: enrich-stop $(TMPDIR)
	@echo ">>> Building Mac Enrich Service..."
	go build -o $(TMPDIR)/mac_enrich_service ./cmd/mac_enrich_service
	@echo ">>> Starting Mac Enrich Service on :$(ENRICH_PORT)..."
	ENRICH_PORT=$(ENRICH_PORT) OLLAMA_URL=$(OLLAMA_URL) \
	  $(TMPDIR)/mac_enrich_service & echo $$! > $(TMPDIR)/enrich.pid
	@echo "  PID: $$(cat $(TMPDIR)/enrich.pid)"
	@sleep 2
	@$(MAKE) -f Makefile.mac health

## Stop Ollama + Enrich Service
stop: enrich-stop
	@if [ -f $(TMPDIR)/ollama.pid ]; then \
		PID=$$(cat $(TMPDIR)/ollama.pid); \
		kill $$PID 2>/dev/null \
			&& echo ">>> Ollama (PID $$PID) stopped" \
			|| echo ">>> Ollama already stopped"; \
		rm -f $(TMPDIR)/ollama.pid; \
	else \
		echo ">>> Ollama not running"; \
	fi

## Stop the Mac Enrich Service
enrich-stop:
	@if [ -f $(TMPDIR)/enrich.pid ]; then \
		PID=$$(cat $(TMPDIR)/enrich.pid); \
		kill $$PID 2>/dev/null \
			&& echo ">>> Enrich Service (PID $$PID) stopped" \
			|| echo ">>> Enrich Service already stopped"; \
		rm -f $(TMPDIR)/enrich.pid; \
	else \
		echo ">>> No enrich service running"; \
	fi

## Health-check the running service
health:
	@curl -sf http://localhost:$(ENRICH_PORT)/health \
		&& echo ">>> Mac Enrich Service healthy" \
		|| echo ">>> WARNING: health check failed"
